# Copy this file to `.env.local` and fill in real values.

# MongoDB connection string
# Local:    mongodb://127.0.0.1:27017/matrimony
# Atlas:    mongodb+srv://<user>:<password>@<cluster>/matrimony?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/matrimony

# Long random string used to sign JWTs (>= 32 chars). Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Public URL where this app is reachable. Used by socket.io client.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: server port (default 3000)
PORT=3000
